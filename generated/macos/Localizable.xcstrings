    "onboarding.description": {
      "comment": "Privacy explanation shown during initial provider setup.",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "new",
            "value": "يُرسل محتواك مباشرةً إلى المزوّد الذي تضبطه. لا يتضمن LinguaMesh أي مفتاح API."
          }
        },
        "ar-XB": {
          "stringUnit": {
            "state": "new",
            "value": "⁧⟦Your content goes directly to the provider you configure. LinguaMesh never bundles an API key.⟧⁩"
          }
        },
        "de": {
          "stringUnit": {
            "state": "new",
            "value": "Ihre Inhalte werden direkt an den konfigurierten Anbieter gesendet. LinguaMesh enthält niemals einen API-Schlüssel."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your content goes directly to the provider you configure. LinguaMesh never bundles an API key."
          }
        },
        "en-XA": {
          "stringUnit": {
            "state": "new",
            "value": "［Ÿøûŕ çøñŧëñŧ ĝøëš ðïŕëçŧŀÿ ŧø ŧħë þŕøṽïðëŕ ÿøû çøñƒïĝûŕë. ĿïñĝûåṀëšħ ñëṽëŕ ƀûñðŀëš åñ ÅÞÏ ķëÿ.~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~］"
          }
        },
        "es": {
          "stringUnit": {
            "state": "new",
            "value": "Tu contenido se envía directamente al proveedor que configures. LinguaMesh nunca incluye una clave de API."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "Votre contenu est envoyé directement au fournisseur que vous configurez. LinguaMesh n’intègre jamais de clé API."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "new",
            "value": "आपकी सामग्री सीधे आपके कॉन्फ़िगर किए गए प्रदाता के पास जाती है। LinguaMesh में कोई API कुंजी शामिल नहीं होती।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "new",
            "value": "コンテンツは設定したプロバイダーに直接送信されます。LinguaMesh に API キーは組み込まれていません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "콘텐츠는 설정한 제공업체로 직접 전송됩니다. LinguaMesh에는 API 키가 포함되어 있지 않습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "new",
            "value": "Seu conteúdo vai diretamente para o provedor configurado. O LinguaMesh nunca inclui uma chave de API."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "Ваш контент отправляется напрямую настроенному поставщику. LinguaMesh не содержит встроенных ключей API."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "new",
            "value": "你的内容会直接发送给你配置的服务提供商。LinguaMesh 不内置任何 API 密钥。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "new",
            "value": "你的內容會直接傳送給你設定的服務供應商。LinguaMesh 不內建任何 API 金鑰。"
          }
        }
      }
    },
